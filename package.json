{
  "name": "@wyre-technology/node-meraki",
  "version": "1.0.0",
  "description": "Node.js client library for the Cisco Meraki Dashboard API v1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "meraki",
    "cisco-meraki",
    "dashboard-api",
    "api",
    "msp",
    "network-management"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/wyre-technology/node-meraki.git"
  },
  "bugs": {
    "url": "https://github.com/wyre-technology/node-meraki/issues"
  },
  "homepage": "https://github.com/wyre-technology/node-meraki#readme",
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^2.0.0",
    "semantic-release": "^25.0.7",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
